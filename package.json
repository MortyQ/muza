{
  "name": "muzakit",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "pnpm --filter @muzakit/app dev",
    "build:libs": "pnpm --filter @muzakit/utils build && pnpm --filter @muzakit/ui build",
    "build": "pnpm run build:libs && pnpm --filter @muzakit/app build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@muzakit/config": "workspace:*",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.0.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "typescript-eslint": "^8.57.0"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": [
      "eslint --fix"
    ]
  }
}
